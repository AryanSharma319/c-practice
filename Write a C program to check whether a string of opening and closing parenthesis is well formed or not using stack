#include<stdlib.h>
#include<stdio.h>

struct Node
{
    char c;
    struct Node *next;
};

struct Stack
{
    struct Node *top;
};

void initialize(struct Stack *stk)
{
    stk->top=NULL;
}

void Push(struct Stack *stk, char c)
{
    struct Node *newnode=malloc(sizeof(struct Node));
    newnode->c=c;
    newnode->next=NULL;
    if(stk->top==NULL)
    {
        stk->top=newnode;
    }
    else
    {
        newnode->next=stk->top;
        stk->top=newnode;
    }
}

char Pop(struct Stack *stk)
{
    if(stk->top==NULL)
    {
        printf("Error");
        return '\0';
    }
    struct Node *del=stk->top;
    char dell=del->c;
    stk->top=stk->top->next;
    free(del);
    return dell;
}

void main(void)
{
    struct Stack *stk=malloc(sizeof(struct Stack));
    initialize(stk);
    char exp[]="{a+(b*c/[d^e]{f))}";
    for(int i=0;exp[i]!='\0';i++)
    {
        if(exp[i]=='{' || exp[i]=='[' || exp[i]=='(')
        {
            Push(stk, exp[i]);
        }
        else if(exp[i]=='}' || exp[i]==']' || exp[i]==')')
        {
            char top=Pop(stk);
            if((exp[i]=='}' && top!='{') || (exp[i]==']' && top!='[') || (exp[i]==')' && top!='('))
            {
                printf("Invalid");
                return;
            }
        }
    }
    printf("Valid");
}
